{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-claude-auth@latest", "opencode-gemini-auth@latest"],
  "lsp": true,
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "${GOOGLE_API_KEY}"
      }
    }
  }
}
