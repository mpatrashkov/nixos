{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Test Nix Config",
      "type": "shell",
      // See `flake.nix` for why the input needs to be overridden like this.
      "command": "./scripts/nix-test",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Switch Nix Config",
      "type": "shell",
      // See `flake.nix` for why the input needs to be overridden like this.
      "command": "./scripts/nix-switch \"${input:commitMessage}\"",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Enter commit message"
    }
  ]
}
