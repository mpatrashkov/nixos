#!/usr/bin/env bash
# Adopt existing files from $HOME into ./dotfiles/<package>, replacing them with symlinks.
# WARNING: --adopt overwrites the in-repo copy with whatever is in $HOME. Review git diff after.
# Usage: stow-adopt <package>
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "usage: $(basename "$0") <package>" >&2
  exit 2
fi

pkg=$1
repo_root=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
cd "$repo_root"

if [ ! -d "./dotfiles/$pkg" ]; then
  echo "error: package './dotfiles/$pkg' does not exist" >&2
  exit 1
fi

stow -d ./dotfiles -t "$HOME" --adopt --verbose=2 "$pkg"
echo
echo "Adopt complete. Review changes with: git status dotfiles/$pkg && git diff dotfiles/$pkg" >&2
